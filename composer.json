{
    "name": "hypejunction/hypediscussions",
    "version": "4.0.0",
    "type": "elgg-plugin",
    "description": "Discussion threads for Elgg",
    "homepage": "http://hypejunction.com",
    "keywords": [
        "elgg",
        "plugin",
        "discussions",
        "groups"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "info@hypejunction.com"
        }
    ],
    "extra": {
        "installer-name": "hypediscussions",
        "elgg-plugin": {
            "id": "hypediscussions"
        }
    },
    "require": {
        "php": ">=7.4",
        "elgg/elgg": "^4.0",
        "composer/installers": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "hypeJunction\\Discussions\\": "classes/hypeJunction/Discussions/",
            "hypeJunction\\": "classes/hypeJunction/"
        },
        "files": [
            "lib/functions.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
